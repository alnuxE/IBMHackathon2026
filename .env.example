# Copia este archivo a `.env` y ajusta los valores.
# docker-compose lo lee automáticamente.

# Credenciales compartidas de las bases de datos Postgres.
DB_USER=neowallet
DB_PASSWORD=neowallet

# Autenticación (JWT). En producción cambia estos valores por secretos fuertes.
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=12h
# Clave para llamadas internas processor → accounts (servicio-a-servicio).
INTERNAL_API_KEY=dev-internal-key
# Contraseña por defecto que se asigna a los 3 usuarios semilla.
SEED_PASSWORD=neowallet123
